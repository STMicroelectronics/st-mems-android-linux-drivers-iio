include Kbuild

ifeq ($(KERNELRELEASE),)

KBUILD_OPTIONS += CONFIG_IIO_ST_IIS2ICLX=m
KBUILD_OPTIONS += CONFIG_IIO_ST_IIS2ICLX_I2C=m
KBUILD_OPTIONS += CONFIG_IIO_ST_IIS2ICLX_SPI=m

KBUILD_OPTIONS += CONFIG_IIO_ST_IIS2ICLX_ASYNC_HW_TIMESTAMP=n
KBUILD_OPTIONS += CONFIG_IIO_ST_IIS2ICLX_MLC_PRELOAD=n

modules:
	$(MAKE) -C $(KDIR) M=$(PWD) modules $(KBUILD_OPTIONS)

modules_install:
	$(MAKE) -C $(KDIR) M=$(PWD) modules_install

clean:
	$(MAKE) -C $(KDIR) M=$(PWD) clean
endif
