# Makefile for industrial I/O ISM330DLC driver
#

include Kbuild

ifeq ($(KERNELRELEASE),)

KBUILD_OPTIONS += CONFIG_ST_ISM330DLC_IIO=m
KBUILD_OPTIONS += CONFIG_ST_ISM330DLC_I2C_IIO=m
KBUILD_OPTIONS += CONFIG_ST_ISM330DLC_SPI_IIO=m

KBUILD_OPTIONS += CONFIG_ST_ISM330DLC_IIO_MASTER_SUPPORT=y
KBUILD_OPTIONS += CONFIG_ST_ISM330DLC_ENABLE_INTERNAL_PULLUP=n
# when MASTER_SUPPORT is enabled, one of the below EXT0 options
# must be enabled (y) to add external sensor support
KBUILD_OPTIONS += CONFIG_ST_ISM330DLC_IIO_EXT0_LIS2MDL=y
KBUILD_OPTIONS += CONFIG_ST_ISM330DLC_IIO_EXT0_LIS3MDL=n
KBUILD_OPTIONS += CONFIG_ST_ISM330DLC_IIO_EXT0_AKM09911=n
KBUILD_OPTIONS += CONFIG_ST_ISM330DLC_IIO_EXT0_AKM09912=n
KBUILD_OPTIONS += CONFIG_ST_ISM330DLC_IIO_EXT0_AKM09916=n
KBUILD_OPTIONS += CONFIG_ST_ISM330DLC_IIO_EXT0_LPS22HB=n

KBUILD_OPTIONS += CONFIG_ST_ISM330DLC_IIO_LIMIT_FIFO=0
KBUILD_OPTIONS += CONFIG_IIO_ST_ISM330DLC_EN_BASIC_FEATURES=n
KBUILD_OPTIONS += CONFIG_ST_ISM330DLC_STEP_COUNTER_ON_DURING_SUSPEND=n
KBUILD_OPTIONS += CONFIG_ST_ISM330DLC_XL_DATA_INJECTION=n

modules:
	$(MAKE) -C $(KDIR) M=$(PWD) modules $(KBUILD_OPTIONS)

modules_install:
	$(MAKE) -C $(KDIR) M=$(PWD) modules_install

clean:
	$(MAKE) -C $(KDIR) M=$(PWD) clean

endif