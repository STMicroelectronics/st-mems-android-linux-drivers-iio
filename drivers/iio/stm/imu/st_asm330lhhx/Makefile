# Makefile for industrial I/O ASM330LHHX driver
#

include Kbuild

ifeq ($(KERNELRELEASE),)

KBUILD_OPTIONS += CONFIG_IIO_ST_ASM330LHHX=m
KBUILD_OPTIONS += CONFIG_IIO_ST_ASM330LHHX_I2C=m
KBUILD_OPTIONS += CONFIG_IIO_ST_ASM330LHHX_SPI=m
ifneq ($(CONFIG_I3C),)
KBUILD_OPTIONS += CONFIG_IIO_ST_ASM330LHHX_I3C=m
endif

KBUILD_OPTIONS += CONFIG_IIO_ST_ASM330LHHX_ASYNC_HW_TIMESTAMP=n
KBUILD_OPTIONS += CONFIG_IIO_ST_ASM330LHHX_STORE_SAMPLE_FIFO_SUSPEND=n
KBUILD_OPTIONS += CONFIG_IIO_ST_ASM330LHHX_MLC_PRELOAD=n

modules:
	$(MAKE) -C $(KDIR) M=$(PWD) modules $(KBUILD_OPTIONS)

modules_install:
	$(MAKE) -C $(KDIR) M=$(PWD) modules_install

clean:
	$(MAKE) -C $(KDIR) M=$(PWD) clean
endif
