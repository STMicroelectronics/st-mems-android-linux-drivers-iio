# Makefile for industrial I/O LSM6DSVX driver
#

include Kbuild

ifeq ($(KERNELRELEASE),)

KBUILD_OPTIONS += CONFIG_IIO_ST_LSM6DSVX=m
KBUILD_OPTIONS += CONFIG_IIO_ST_LSM6DSVX_I2C=m
KBUILD_OPTIONS += CONFIG_IIO_ST_LSM6DSVX_SPI=m

ifneq ($(CONFIG_I3C),)
KBUILD_OPTIONS += CONFIG_IIO_ST_LSM6DSVX_I3C=m
endif

KBUILD_OPTIONS += CONFIG_IIO_ST_LSM6DSVX_ASYNC_HW_TIMESTAMP=n
KBUILD_OPTIONS += CONFIG_IIO_ST_LSM6DSVX_MLC_PRELOAD=n
KBUILD_OPTIONS += CONFIG_IIO_ST_LSM6DSVX_QVAR_IN_FIFO=n

modules:
	$(MAKE) -C $(KDIR) M=$(PWD) modules $(KBUILD_OPTIONS)

modules_install:
	$(MAKE) -C $(KDIR) M=$(PWD) modules_install

clean:
	$(MAKE) -C $(KDIR) M=$(PWD) clean
endif
