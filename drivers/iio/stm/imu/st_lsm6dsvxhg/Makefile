# Makefile for industrial I/O LSM6DSVXHG driver
#

include Kbuild

ifeq ($(KERNELRELEASE),)

KBUILD_OPTIONS += CONFIG_IIO_ST_LSM6DSVXHG=m
KBUILD_OPTIONS += CONFIG_IIO_ST_LSM6DSVXHG_I2C=m
KBUILD_OPTIONS += CONFIG_IIO_ST_LSM6DSVXHG_SPI=m

ifneq ($(CONFIG_I3C),)
KBUILD_OPTIONS += CONFIG_IIO_ST_LSM6DSVXHG_I3C=m
endif

KBUILD_OPTIONS += CONFIG_IIO_ST_LSM6DSVXHG_ASYNC_HW_TIMESTAMP=n
KBUILD_OPTIONS += CONFIG_IIO_ST_LSM6DSVXHG_MLC_PRELOAD=n

modules:
	$(MAKE) -C $(KDIR) M=$(PWD) modules $(KBUILD_OPTIONS)

modules_install:
	$(MAKE) -C $(KDIR) M=$(PWD) modules_install

clean:
	$(MAKE) -C $(KDIR) M=$(PWD) clean
endif
