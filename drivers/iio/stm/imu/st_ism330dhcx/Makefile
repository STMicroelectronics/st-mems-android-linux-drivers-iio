# Makefile for industrial I/O ISM330DHCX driver
#

include Kbuild

ifeq ($(KERNELRELEASE),)

KBUILD_OPTIONS += CONFIG_IIO_ST_ISM330DHCX=m
KBUILD_OPTIONS += CONFIG_IIO_ST_ISM330DHCX_I2C=m
KBUILD_OPTIONS += CONFIG_IIO_ST_ISM330DHCX_SPI=m

KBUILD_OPTIONS += CONFIG_IIO_ST_ISM330DHCX_ASYNC_HW_TIMESTAMP=n
KBUILD_OPTIONS += CONFIG_IIO_ST_ISM330DHCX_MLC_PRELOAD=n

modules:
	$(MAKE) -C $(KDIR) M=$(PWD) modules $(KBUILD_OPTIONS)

modules_install:
	$(MAKE) -C $(KDIR) M=$(PWD) modules_install

clean:
	$(MAKE) -C $(KDIR) M=$(PWD) clean
endif
